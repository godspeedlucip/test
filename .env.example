# Core provider mode switches: mock | real | hybrid
LLM_PROVIDER_MODE=mock
TRACE_STORE_PROVIDER=mock
OBJECT_STORE_PROVIDER=mock
VECTOR_STORE_PROVIDER=mock
JAVA_CLIENT_MODE=mock
ACADEMIC_PROVIDER_MODE=mock

# LLM
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini

# Trace store
TRACE_STORE_ROOT=.artifacts/traces

# Object store
OBJECT_STORE_ROOT=.artifacts/object_store

# Vector store
VECTOR_STORE_ROOT=.artifacts/vector_store

# Java platform
JAVA_CLIENT_BASE_URL=
JAVA_CLIENT_TIMEOUT_SECONDS=5
JAVA_CLIENT_AUTH_HEADER=
JAVA_CLIENT_MAX_RETRIES=2
JAVA_CLIENT_RETRY_BACKOFF_SECONDS=0.1
