RUNTIME_ENV=dev

# Provider modes
LLM_PROVIDER_MODE=real
TRACE_STORE_PROVIDER=real
OBJECT_STORE_PROVIDER=real
VECTOR_STORE_PROVIDER=real
JAVA_CLIENT_MODE=mock
ACADEMIC_PROVIDER_MODE=real

# Real embedding transport is not wired in this repo yet; keep local for stability.
EMBED_PROVIDER_MODE=local

# LLM (OpenAI-compatible)
LLM_API_KEY=c46cfe38-1e3c-4c6e-94ae-a2402873bd1a
LLM_MODEL_NAME=Doubao-Seed-1.8_TPM_IN10K
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Academic search (OpenAlex)
OPENALEX_MAILTO=your-email@example.com
OPENALEX_TIMEOUT_SECONDS=10

# Local artifact stores
TRACE_STORE_ROOT=.artifacts/traces
OBJECT_STORE_ROOT=.artifacts/object_store
VECTOR_STORE_ROOT=.artifacts/vector_store

# Java platform
JAVA_CLIENT_BASE_URL=
JAVA_CLIENT_TIMEOUT_SECONDS=5
JAVA_CLIENT_AUTH_HEADER=
JAVA_CLIENT_MAX_RETRIES=2
JAVA_CLIENT_RETRY_BACKOFF_SECONDS=0.1
